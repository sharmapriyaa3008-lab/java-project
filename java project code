import java.util.Scanner;

interface Service {
    double calculateBill(int roomNumber, int days);
}

class Room {
    int roomNumber;
    String roomType;
    double pricePerDay;
    boolean available;

    Room(int roomNumber, String roomType, double pricePerDay) {
        this.roomNumber = roomNumber;
        this.roomType = roomType;
        this.pricePerDay = pricePerDay;
        this.available = true;
    }
}

class Hotel implements Service {

    private Room[][] rooms;

    public Hotel(int floors, int roomsPerFloor) {

        rooms = new Room[floors][roomsPerFloor];

        int roomNo = 101;

        for (int i = 0; i < floors; i++) {

            for (int j = 0; j < roomsPerFloor; j++) {

                String type;
                double price;

                if (j % 3 == 0) {
                    type = "Standard";
                    price = 1500;
                } else if (j % 3 == 1) {
                    type = "Deluxe";
                    price = 2500;
                } else {
                    type = "Suite";
                    price = 4000;
                }

                rooms[i][j] = new Room(roomNo++, type, price);
            }
        }
    }

    public void displayRooms() {

        System.out.println("\n===== ROOM STATUS =====");

        for (Room[] floor : rooms) {

            for (Room room : floor) {

                System.out.println(
                        "Room " + room.roomNumber +
                        " | " + room.roomType +
                        " | " +
                        (room.available ? "Available" : "Occupied"));
            }
        }
    }

    public void bookRoom(int roomNumber) {

        for (Room[] floor : rooms) {

            for (Room room : floor) {

                if (room.roomNumber == roomNumber) {

                    if (room.available) {

                        room.available = false;
                        System.out.println("Room booked successfully.");

                    } else {

                        System.out.println("Room already occupied.");
                    }

                    return;
                }
            }
        }

        System.out.println("Room not found.");
    }

    public void cancelBooking(int roomNumber) {

        for (Room[] floor : rooms) {

            for (Room room : floor) {

                if (room.roomNumber == roomNumber) {

                    if (!room.available) {

                        room.available = true;
                        System.out.println("Booking cancelled successfully.");

                    } else {

                        System.out.println("Room is already available.");
                    }

                    return;
                }
            }
        }

        System.out.println("Room not found.");
    }

    @Override
    public double calculateBill(int roomNumber, int days) {

        for (Room[] floor : rooms) {

            for (Room room : floor) {

                if (room.roomNumber == roomNumber) {

                    return room.pricePerDay * days;
                }
            }
        }

        return 0;
    }
}

public class HotelReservationSystem {

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        Hotel hotel = new Hotel(3, 5);

        while (true) {

            System.out.println("\n===== HOTEL ROOM RESERVATION SYSTEM =====");
            System.out.println("1. View Rooms");
            System.out.println("2. Book Room");
            System.out.println("3. Cancel Booking");
            System.out.println("4. Calculate Bill");
            System.out.println("5. Exit");

            System.out.print("Enter your choice: ");
            int choice = sc.nextInt();

            switch (choice) {

                case 1:
                    hotel.displayRooms();
                    break;

                case 2:
                    System.out.print("Enter Room Number: ");
                    int bookRoom = sc.nextInt();
                    hotel.bookRoom(bookRoom);
                    break;

                case 3:
                    System.out.print("Enter Room Number: ");
                    int cancelRoom = sc.nextInt();
                    hotel.cancelBooking(cancelRoom);
                    break;

                case 4:
                    System.out.print("Enter Room Number: ");
                    int roomNo = sc.nextInt();

                    System.out.print("Enter Number of Days: ");
                    int days = sc.nextInt();

                    double bill = hotel.calculateBill(roomNo, days);

                    if (bill > 0) {
                        System.out.println("Total Bill = Rs. " + bill);
                    } else {
                        System.out.println("Invalid Room Number.");
                    }
                    break;

                case 5:
                    System.out.println("Thank You!");
                    sc.close();
                    System.exit(0);
                    break;

                default:
                    System.out.println("Invalid Choice.");
            }
        }
    }
}
